# Local .terraform directories
**/.terraform/*

# .tfvars files (contains secrets/variables)
*.tfvars
*.tfvars.json

# Local state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude plan outputs
*.tfplan

# Override files
*.override.tf
*.override.tf.json
*_override.tf
*_override.tf.json

# Include override directory
.terraform.d/

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Editor / OS Noise
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db
node_modules/
