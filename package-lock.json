{
  "name": "kesahomma26-monorepo",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "kesahomma26-monorepo",
      "version": "1.0.0",
      "workspaces": [
        "apps/*"
      ]
    },
    "apps/agents": {
      "name": "@kesahomma26/agents",
      "version": "0.1.0"
    },
    "apps/api": {
      "name": "@kesahomma26/api",
      "version": "0.1.0"
    },
    "apps/frontend": {
      "name": "@kesahomma26/frontend",
      "version": "0.1.0"
    },
    "node_modules/@kesahomma26/agents": {
      "resolved": "apps/agents",
      "link": true
    },
    "node_modules/@kesahomma26/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@kesahomma26/frontend": {
      "resolved": "apps/frontend",
      "link": true
    }
  }
}
